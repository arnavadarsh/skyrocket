// SkyConnect — Airport Management System
// Final schema (11 tables). Paste into https://dbdiagram.io to export
// an ER diagram. Matches schema.sql exactly.
// Project: https://localhost/flight

Project SkyConnect {
  database_type: 'MySQL'
  Note: 'Flight booking + airport operations. 11 tables, InnoDB, utf8mb4.'
}

Table users {
  user_id    int [pk, increment]
  username   varchar(50)  [not null, unique]
  email      varchar(100) [not null, unique]
  password   varchar(255) [not null, note: 'bcrypt hash']
  first_name varchar(50)  [not null]
  last_name  varchar(50)  [not null]
  role       varchar [not null, default: 'user', note: "ENUM('user','staff','admin')"]
  created_at timestamp [default: `CURRENT_TIMESTAMP`]
}

Table aircraft {
  aircraft_id        int [pk, increment]
  model              varchar(50) [not null]
  capacity           int [not null, note: 'CHECK capacity > 0']
  maintenance_status varchar [not null, default: 'active', note: "ENUM('active','maintenance','retired')"]
}

Table gates {
  gate_id     int [pk, increment]
  terminal    varchar [not null, note: "ENUM('T1','T2','T3')"]
  gate_number varchar(4) [not null]
  status      varchar [not null, default: 'open', note: "ENUM('open','closed')"]

  indexes {
    (terminal, gate_number) [unique]
  }
}

Table flights {
  flight_id       int [pk, increment]
  flight_number   varchar(10) [not null]
  airline         varchar(50) [not null]
  departure_city  varchar(50) [not null]
  arrival_city    varchar(50) [not null]
  departure_time  datetime [not null]
  arrival_time    datetime [not null, note: 'CHECK arrival_time > departure_time']
  available_seats int [not null, note: 'CHECK >= 0; maintained by ticket triggers']
  economy_price   decimal(10,2) [not null, note: 'CHECK > 0']
  business_price  decimal(10,2) [not null, note: 'CHECK > 0']
  first_price     decimal(10,2) [not null, note: 'CHECK > 0']
  status          varchar [not null, default: 'scheduled', note: "ENUM('scheduled','delayed','boarding','departed','arrived','cancelled')"]
  aircraft_id     int [null]
  gate_id         int [null]

  indexes {
    (flight_number, departure_time) [unique]
    (departure_city, arrival_city, departure_time) [name: 'idx_flights_route_time']
  }
}

Table bookings {
  booking_id       int [pk, increment]
  user_id          int [not null]
  flight_id        int [not null]
  return_flight_id int [null, note: 'NULL = one-way; non-NULL = round trip']
  booking_date     timestamp [default: `CURRENT_TIMESTAMP`]
  passenger_count  int [not null, default: 1, note: 'CHECK BETWEEN 1 AND 9']
  total_price      decimal(10,2) [not null, note: 'CHECK >= 0']
  class            varchar [not null, default: 'economy', note: "ENUM('economy','business','first')"]
  status           varchar [not null, default: 'pending', note: "ENUM('pending','confirmed','cancelled')"]
}

Table passengers {
  passenger_id int [pk, increment]
  booking_id   int [not null]
  full_name    varchar(100) [not null]
  dob          date [not null, note: 'past-date validated in PHP (CURDATE not allowed in CHECK)']
  gender       varchar [not null, note: "ENUM('male','female','other')"]
  passport_no  varchar(20) [null]
}

Table tickets {
  ticket_id    int [pk, increment]
  booking_id   int [not null]
  passenger_id int [not null]
  flight_id    int [not null]
  seat_number  varchar(4) [null, note: 'NULLed on cancel to free the seat']
  class        varchar [not null, note: "ENUM('economy','business','first')"]
  fare         decimal(10,2) [not null, note: 'CHECK >= 0; price snapshot at booking time']
  status       varchar [not null, default: 'confirmed', note: "ENUM('confirmed','checked_in','cancelled')"]

  indexes {
    (flight_id, seat_number) [unique, note: 'one passenger per seat; multiple NULLs allowed']
  }
}

Table payments {
  payment_id int [pk, increment]
  booking_id int [not null]
  amount     decimal(10,2) [not null, note: 'CHECK >= 0']
  method     varchar [not null, note: "ENUM('card','upi','netbanking')"]
  status     varchar [not null, default: 'pending', note: "ENUM('pending','completed','refunded')"]
  txn_ref    varchar(40) [null]
  paid_at    datetime [null]
}

Table employees {
  employee_id  int [pk, increment]
  full_name    varchar(100) [not null]
  role         varchar [not null, note: "ENUM('pilot','cabin_crew','ground','security')"]
  contact_info varchar(100) [null]
  shift        varchar [not null, note: "ENUM('morning','evening','night')"]
}

Table employee_flight_assignment {
  assignment_id int [pk, increment]
  employee_id   int [not null]
  flight_id     int [not null]
  assigned_at   timestamp [default: `CURRENT_TIMESTAMP`]

  indexes {
    (employee_id, flight_id) [unique, note: 'crew M:N junction; one row per employee per flight']
  }
}

Table luggage {
  luggage_id int [pk, increment]
  ticket_id  int [not null]
  weight     decimal(5,2) [not null, note: 'CHECK weight > 0 AND weight <= 32']
  status     varchar [not null, default: 'checked_in', note: "ENUM('checked_in','loaded','arrived','lost')"]
  created_at timestamp [default: `CURRENT_TIMESTAMP`]
}

// ---- Relationships (with ON DELETE behavior) ----
Ref: bookings.user_id          > users.user_id        [delete: restrict]
Ref: bookings.flight_id        > flights.flight_id    [delete: restrict]
Ref: bookings.return_flight_id > flights.flight_id    [delete: restrict]
Ref: flights.aircraft_id       > aircraft.aircraft_id [delete: restrict]
Ref: flights.gate_id           > gates.gate_id        [delete: set null]
Ref: passengers.booking_id     > bookings.booking_id  [delete: cascade]
Ref: tickets.booking_id        > bookings.booking_id  [delete: cascade]
Ref: tickets.passenger_id      > passengers.passenger_id [delete: cascade]
Ref: tickets.flight_id         > flights.flight_id    [delete: restrict]
Ref: payments.booking_id       > bookings.booking_id  [delete: cascade]
Ref: employee_flight_assignment.employee_id > employees.employee_id [delete: cascade]
Ref: employee_flight_assignment.flight_id   > flights.flight_id     [delete: cascade]
Ref: luggage.ticket_id         > tickets.ticket_id    [delete: cascade]
