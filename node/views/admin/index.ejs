<%- include('../partials/admin_header') %>
<div class="admin-container">
    <h1>Admin Dashboard</h1>

    <div class="stats-container">
        <div class="stat-card"><h3>Total Bookings</h3><div class="stat-number"><%= bookings_count %></div></div>
        <div class="stat-card"><h3>Total Users</h3><div class="stat-number"><%= users_count %></div></div>
        <div class="stat-card"><h3>Total Flights</h3><div class="stat-number"><%= flights_count %></div></div>
        <div class="stat-card"><h3>Total Revenue</h3><div class="stat-number">&#8377;<%= h.nf2(total_revenue) %></div></div>
        <div class="stat-card"><h3>Pending Payments</h3><div class="stat-number"><%= pending_payments %></div></div>
    </div>

    <div class="admin-links">
        <a href="/admin/bookings" class="admin-link-card"><h3>Manage Bookings</h3><p>View and manage all flight bookings</p></a>
        <a href="/admin/users" class="admin-link-card"><h3>Manage Users</h3><p>View and manage user accounts</p></a>
        <a href="/admin/flights" class="admin-link-card"><h3>Manage Flights</h3><p>View and manage available flights with pricing tiers</p></a>
        <a href="/admin/custom_query" class="admin-link-card"><h3>Custom SQL Query</h3><p>Execute custom SQL queries on the database</p></a>
    </div>

    <div class="admin-card" style="margin-top:30px;">
        <h2>Recent Bookings</h2>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr><th>ID</th><th>User</th><th>Flight</th><th>Class</th><th>Status</th><th>Date</th><th>Price</th><th>Action</th></tr>
                </thead>
                <tbody>
                    <% if (recent_bookings.length > 0) { %>
                        <% recent_bookings.forEach(function(b) { %>
                            <tr>
                                <td>#<%= b.booking_id %></td>
                                <td><%= b.username %></td>
                                <td><%= b.flight_number %></td>
                                <td><%= b.class_type || 'Economy' %></td>
                                <td><% if (b.status === 'cancelled') { %><span class="status-badge status-cancelled">Cancelled</span><% } else { %><span class="status-badge status-scheduled">Confirmed</span><% } %></td>
                                <td><%= h.phpDate('M d, Y', b.booking_date) %></td>
                                <td>&#8377;<%= h.nf2(b.total_price) %></td>
                                <td><a href="/admin/bookings" class="btn btn-sm">View</a></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="8" class="text-center">No bookings found</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('../partials/console_footer') %>
