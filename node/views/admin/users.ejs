<%- include('../partials/admin_header') %>
<div class="admin-container">
    <h1>Manage Users</h1>
    <%- include('../partials/messages') %>

    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>Username</th><th>Name</th><th>Email</th><th>Role</th><th>Created</th><th>Actions</th></tr>
            </thead>
            <tbody>
                <% if (users.length > 0) { %>
                    <% users.forEach(function(u) { %>
                        <tr>
                            <td>#<%= u.user_id %></td>
                            <td><%= u.username %></td>
                            <td><%= u.first_name %> <%= u.last_name %></td>
                            <td><%= u.email %></td>
                            <td>
                                <% if (u.role === 'admin') { %><span class="badge badge-admin">Admin</span>
                                <% } else if (u.role === 'staff') { %><span class="badge badge-admin">Staff</span>
                                <% } else { %><span class="badge badge-user">User</span><% } %>
                            </td>
                            <td><%= h.phpDate('M d, Y', u.created_at) %></td>
                            <td>
                                <% if (u.user_id != session.user_id) { %>
                                    <form action="/admin/users" method="post" class="status-form" style="display:inline-flex">
                                        <%- csrf_field() %>
                                        <input type="hidden" name="user_id" value="<%= u.user_id %>">
                                        <select name="role" class="form-control status-select">
                                            <% ['user','staff','admin'].forEach(function(r) { %>
                                                <option value="<%= r %>" <%= u.role === r ? 'selected' : '' %>><%= h.ucfirst(r) %></option>
                                            <% }) %>
                                        </select>
                                        <button type="submit" name="update_role" value="1" class="btn btn-sm">Update</button>
                                    </form>
                                    <form action="/admin/users" method="post" onsubmit="return confirm('Are you sure you want to delete this user?')" style="display:inline">
                                        <%- csrf_field() %>
                                        <button type="submit" name="delete_user" value="<%= u.user_id %>" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="7" class="text-center">No users found</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
<%- include('../partials/console_footer') %>
